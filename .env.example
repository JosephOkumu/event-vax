# ============================================
# EventVerse - Environment Configuration
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080

# ============================================
# BLOCKCHAIN CONFIGURATION (Avalanche Fuji Testnet)
# ============================================
AVALANCHE_RPC=https://api.avax-test.network/ext/bc/C/rpc

# ============================================
# IPFS STORAGE (Choose one service)
# ============================================

# Pinata (Recommended - https://pinata.cloud)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
PINATA_SECRET_JWT=your_pinata_jwt_token_here

# NFT.Storage (Alternative - https://nft.storage)
NFT_STORAGE_API_KEY=your_nft_storage_api_key_here

# Web3.Storage (Alternative - https://web3.storage)
WEB3_STORAGE_API_KEY=your_web3_storage_api_key_here

# ============================================
# DEPLOYED CONTRACT ADDRESSES (Avalanche Fuji Testnet)
# ============================================
TICKET_NFT_IMPLEMENTATION=0x520B9d1C86d2dD58b5929AC159aF06508160aDec
EVENT_MANAGER=0x5876444b87757199Cd08f44193Bf7741FDA01EAD
MARKETPLACE=0x072c6707E3fd1Bcc2f2177349402Ad5fdeB82F51
EVENT_FACTORY=0x4FC9267E6Ef419be7700e3936Fc51D2835e257D0
QR_VERIFICATION_SYSTEM=0x89dABaf2dC7aF4C06AF993E083115952cCd67E86
POAP=0x323A6ddC3390192013bfe09Ea7d677c7469078c4
EVENT_BADGE=0xCB3c41286536004dee308520B4D1F64de20157DB
METADATA_REGISTRY=0xCD2bA7f0941A0A79aC791Fb5D72E493557c37241

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite database path (relative to server directory)
DATABASE_PATH=./data/events.db

# ============================================
# SECURITY & API KEYS
# ============================================
# JWT Secret for authentication (if implementing auth)
JWT_SECRET=your_jwt_secret_here

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
NODE_ENV=development

# ============================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================
# Email service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Analytics (if using)
GOOGLE_ANALYTICS_ID=your_ga_id_here

# ============================================
# BLOCKCHAIN DEPLOYMENT (For contract deployment)
# ============================================
# Private key for deploying contracts (NEVER commit this!)
PRIVATE_KEY=your_private_key_here

# Snowtrace API key for contract verification
SNOWTRACE_API_KEY=your_snowtrace_api_key_here

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# These should be in a separate .env file in the root directory
# with VITE_ prefix for Vite to expose them to the frontend

# VITE_PINATA_API_KEY=your_pinata_api_key_here
# VITE_PINATA_SECRET_KEY=your_pinata_secret_key_here
# VITE_API_URL=http://localhost:8080
# VITE_CHAIN_ID=43113
# VITE_NETWORK_NAME=Avalanche Fuji Testnet

# ============================================
# NOTES
# ============================================
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env files to version control
# 3. For production, use environment-specific values
# 4. Pinata JWT is recommended over API key/secret
# 5. Keep private keys secure and never share them
